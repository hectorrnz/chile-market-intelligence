# Nevada Market Intelligence — environment variables template
# Copy this file to .env.local and fill in real values.
# Never commit .env.local to version control.
#
# The app runs fully on static MVP data with NO variables set. Everything below
# is optional and only activates live data once configured.

# ── Phase 4A: Data mode ───────────────────────────────────────────────────────
# static = local JSON only · live = live provider (error/fallback if it fails)
# hybrid = try live, fall back to static. If unset: defaults to hybrid when BCCh
# credentials exist, otherwise static.
DATA_MODE=static

# ── Phase 4A: Banco Central de Chile (BDE / SieteRestWS) ──────────────────────
# Server-only — NEVER prefix with NEXT_PUBLIC. Leave blank to stay on static.
# Official BDE series codes are mapped in src/config/macroSeries.ts (Phase 4B).
BCCH_API_USER=
BCCH_API_PASSWORD=
BCCH_API_BASE_URL=https://si3.bcentral.cl/SieteRestWS/SieteRestWS.ashx

# ── Phase 4C: Market data (Bolsa de Santiago / Brain Data) ────────────────────
# Server-only — NEVER prefix with NEXT_PUBLIC.
# Leave blank to serve static market data (stocks, indices, sectors, history).
# static = local JSON only | live = Brain Data only (error if unavailable)
# hybrid = try Brain Data, fall back to static. Unset = static.
MARKET_DATA_MODE=static
# Brain Data / Bolsa de Santiago API credentials — exact fields may vary.
# Obtain via official registration at https://www.braindata.cl (as of 2026).
# The exact auth method (API key vs OAuth2 client credentials) must be confirmed
# against the official Brain Data OpenAPI documentation before enabling.
BRAIN_DATA_API_BASE_URL=
BRAIN_DATA_API_KEY=
# Optional: OAuth2 client credentials if Brain Data uses client_credentials flow.
# BRAIN_DATA_CLIENT_ID=
# BRAIN_DATA_CLIENT_SECRET=
# BRAIN_DATA_AUTH_URL=

# ── Phase 5B: Supabase persistence ───────────────────────────────────────────
# DB_MODE controls repository layer: static | supabase | hybrid (default: static)
#   static   = JSON/provider fallback only (no DB required)
#   supabase = Supabase only; clean error if not configured
#   hybrid   = try Supabase first, fall back to static
# The app builds and runs with no Supabase env vars set (static mode).
DB_MODE=static
#
# Public (safe for browser bundle) — used by client.ts only.
# Obtain from your Supabase project dashboard → Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
#
# Server-only secrets — NEVER prefix with NEXT_PUBLIC, NEVER log, NEVER import
# into client components. Read only inside server route handlers and admin scripts.
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Postgres connection string — server-only; used only for direct DB scripts/migrations.
# Format: postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
SUPABASE_DATABASE_URL=

# ── Phase 4C.2: Market snapshot ingestion ────────────────────────────────────
# Server-only secret for /api/cron/ingest-market-snapshot.
# Generate: openssl rand -hex 32
# Add to Vercel (Preview + Production) and GitHub repository secrets.
# NEVER prefix with NEXT_PUBLIC_. NEVER log. NEVER commit the real value.
MARKET_INGEST_SECRET=

# ── Phase 5D.1: Ingestion health alerting ────────────────────────────────────
# Master switch — set to 'true' to enable webhook delivery. Default: false (disabled).
ALERTS_ENABLED=false
#
# Generic webhook URL (Slack, Teams, Discord, or any HTTP POST endpoint).
# Payload: JSON with text, status, generatedAt, alertCount, alerts[].
# NEVER commit the real URL. NEVER prefix with NEXT_PUBLIC_.
ALERT_WEBHOOK_URL=
#
# Optional bearer token sent as Authorization: Bearer <secret> in webhook POST.
# Leave blank for unauthenticated webhooks (e.g. Slack incoming webhooks).
ALERT_WEBHOOK_SECRET=
#
# Optional: recipient email for future email delivery (not implemented in 5D.1).
ALERT_EMAIL_TO=

# ── Phase 6A: Auth + Watchlist ───────────────────────────────────────────────
# Base URL of the site. In Vercel this is set automatically; for local dev set
# to http://localhost:3000. Optional.
NEXT_PUBLIC_SITE_URL=

# ── Phase 6B: Username + Password Auth ───────────────────────────────────────
# Optional gate for account creation. When set, POST /api/auth/register requires
# a matching `code` in the request body. Leave unset to allow open registration.
# Set this (and add a code field to the signup form) to lock down account creation.
# AUTH_REGISTRATION_CODE=

# ── Phase 8D.1: FRED release-date calendar (dates only) ─────────────────────
# Server-only — NEVER prefix with NEXT_PUBLIC. Free, immediate self-service key
# from https://fred.stlouisfed.org/docs/api/api_key.html. Used ONLY by
# src/lib/providers/fredReleaseCalendarClient.ts to fetch official release
# DATES (no consensus/actual/prior values) for GET /api/macro/fred-release-calendar.
# The US macro time-series values (Fed Funds, CPI, Treasury yields, etc.) use the
# separate free FRED CSV endpoint and need no key at all — this key is only for
# the release-dates calendar feature. Leave blank to disable the calendar panel
# (the rest of the app is unaffected).
FRED_API_KEY=

# ── CurrencyFreaks (DEPRECATED — no longer used by any production route) ────
# The Macro / US forex table moved to Frankfurter (free, no API key — see
# frankfurterClient.ts/frankfurterFxProvider.ts) because CurrencyFreaks' free
# plan had no historical/change data. This key is left here (and remains
# configured in Vercel) only in case a future need for CurrencyFreaks-specific
# data arises; `src/lib/providers/currencyFreaksClient.ts` still reads it but
# is not imported by any production page or route. Safe to leave blank.
CURRENCYFREAKS_API_KEY=

# ── Frankfurter: Macro / US forex table (free, no API key) ───────────────────
# No env var needed — Frankfurter (https://api.frankfurter.dev) is a free,
# open-source, keyless exchange-rate API sourcing from 84 central banks. Used
# by src/lib/providers/frankfurterClient.ts /frankfurterFxProvider.ts to serve
# GET /api/macro/fx/us (USD-base pairs + real 1D/YTD change), cached
# server-side for 6 hours. Chile FX is entirely separate and stays
# BCCh-official — Frankfurter is never used for Chile pairs.

# ── Notifications: Resend email delivery ─────────────────────────────────────
# Server-only — NEVER prefix with NEXT_PUBLIC, NEVER log. Free self-service key
# from https://resend.com/api-keys. Used only by
# src/lib/notifications/emailProvider.ts to email the configured recipient list
# (managed at /settings/notifications) when a platform notification is created
# (e.g. a structured note is auto-called). Leave blank to disable email delivery
# — in-app notifications (bell icon + unread badge) still work with no key set.
RESEND_API_KEY=
# "From" address for outbound notification emails. Must be either a verified
# sending domain in your Resend account, or Resend's shared test address
# (onboarding@resend.dev) which works without domain verification.
NOTIFICATION_EMAIL_FROM=onboarding@resend.dev

# ── Future: News ingestion ────────────────────────────────────────────────────
# NEWS_API_KEY=
