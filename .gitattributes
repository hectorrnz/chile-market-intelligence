# Normalize line endings to LF in the repo; checkout converts to CRLF on Windows.
* text=auto eol=lf

# Force these to stay LF everywhere (scripts, configs)
*.sh text eol=lf
*.mjs text eol=lf

# Binary files — no line-ending conversion
*.png binary
*.jpg binary
*.ico binary
*.woff2 binary
*.woff binary
